class Solution {
public:
    int countSubarray(vector<int>& arr) {

        unordered_map<int,int> mp;

        int sum = 0;
        int ans = 0;

        mp[0] = 1;

        for(int i = 0; i < arr.size(); i++)
        {
            if(arr[i] == 0)
                sum += -1;
            else
                sum += 1;

            if(mp.find(sum) != mp.end())
            {
                ans += mp[sum];
            }

            mp[sum]++;
        }

        return ans;
    }
};
